animations {
  slowdown 0.86

  horizontal-view-movement {
    spring damping-ratio=1.05 stiffness=1200 epsilon=0.00015
  }

  window-movement {
    spring damping-ratio=1.05 stiffness=1200 epsilon=0.00015
  }

  window-resize {
    spring damping-ratio=1.05 stiffness=1200 epsilon=0.00015
  }

  overview-open-close {
    spring damping-ratio=1.02 stiffness=1100 epsilon=0.00015
  }

  workspace-switch {
    spring damping-ratio=1.08 stiffness=1300 epsilon=0.00015
  }
}
