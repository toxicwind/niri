#!/usr/bin/env bash
set -euo pipefail

SRC="${HOME}/.config/niri/apex-niri-toxicwind/contrib/third_party/dms-display-mirror"
DST_DIR="${HOME}/.config/DankMaterialShell/plugins"
DST="${DST_DIR}/dms-display-mirror"

if [[ ! -d "${SRC}" ]]; then
  echo "Missing submodule at ${SRC}" >&2
  exit 1
fi

mkdir -p "${DST_DIR}"
ln -sfn "${SRC}" "${DST}"

echo "Linked DMS mirror plugin:" 
echo "  ${DST} -> ${SRC}"
echo "Now open DMS Settings -> Plugins -> Scan -> enable Display Mirror."
