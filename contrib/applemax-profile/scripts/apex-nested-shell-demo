#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "${SCRIPT_DIR}/apex-niri-helpers"

CANVAS="${1:-3840x1440}"
USE_GAMESCOPE="${USE_GAMESCOPE:-1}"

HOST_CFG="${XDG_CONFIG_HOME:-$HOME/.config}/niri/config.kdl"
TMP_DIR="$(mktemp -d)"
TMP_CFG="${TMP_DIR}/config.kdl"
trap 'rm -rf "${TMP_DIR}"' EXIT

if [[ -f "${HOST_CFG}" ]]; then
  cp -f "${HOST_CFG}" "${TMP_CFG}"
else
  cp -f "${HOME}/.config/niri/apex-niri-toxicwind/contrib/applemax-profile/config.default.applemax.example.kdl" "${TMP_CFG}"
fi

# Nested mode must never run with --session.
LAUNCH_CMD=(bash -lc "~/.config/apex/scripts/apex-nested-shell-driver")

apex_popup_info "Launching nested niri demo.\n\nThis is isolated from your active niri/DMS session.\nClose nested window to exit." "AppleMax Nested Demo"

if [[ "${USE_GAMESCOPE}" == "1" ]] && command -v gamescope >/dev/null 2>&1; then
  W="${CANVAS%x*}"
  H="${CANVAS#*x}"
  exec gamescope -W "$W" -H "$H" -w "$W" -h "$H" -- niri -c "${TMP_CFG}" -- "${LAUNCH_CMD[@]}"
fi

exec niri -c "${TMP_CFG}" -- "${LAUNCH_CMD[@]}"
